{
  "name": "ootd-it",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "fuser -k 10000/tcp || true && vite --host 0.0.0.0 --port 10000 & wait-on tcp:10000 && npx wrangler dev --local-upstream localhost:10000 --port 10001 --ip 0.0.0.0",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "npm run build && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.5",
    "wrangler": "^4.83.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
